{% package html %}

{% func SSOFailurePopup(reason string) %}
<!DOCTYPE html>
<html lang="en">
    <script>
        async function onAuthFailure() {
            window.opener?.postMessage({ success: false}, window.location.origin);
            window.close();
        }
        window.addEventListener('beforeunload', onAuthFailure)
    </script>
    <body>
        <h2>{%s reason %}</h2>
    </body>
</html>
{% endfunc %}